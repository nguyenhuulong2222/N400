# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# NOTE: `mobile/data.json` is intentionally TRACKED so EAS cloud builds receive
# it. It is regenerated from the canonical repo-root `data.json` by the
# `npm run sync-data` script (also wired into the prestart hook). After any
# `node tools/build-app-data.js --apply` run, run `cd mobile && npm run sync-data`
# and commit the resulting mobile/data.json so the mobile bundle stays in sync.
