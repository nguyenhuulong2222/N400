{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "expo": "~56.0.8",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.17",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "sync-data": "node -e \"require('fs').copyFileSync('../data.json','./data.json')\"",
    "prestart": "npm run sync-data",
    "preandroid": "npm run sync-data",
    "preios": "npm run sync-data",
    "preweb": "npm run sync-data",
    "smoke:quiz": "npm run sync-data && node scripts/smoke-quiz-engine.ts",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "private": true
}
